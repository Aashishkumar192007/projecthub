generator client {
  provider = "prisma-client-js"
}

generator api_client {
  provider = "prisma-client-js"
  output   = "../apps/api/node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =========================================================================
// 1. GLOBAL & IDENTITY MANAGEMENT
// =========================================================================

model Tenant {
  tenant_id     String   @id @default(uuid())
  name          String
  slug          String   @unique
  business_type String
  plan          String
  schema_name   String
  status        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users           User[]           @relation("TenantUsers")
  roles           Role[]
  roleAssignments RoleAssignment[]
  properties      Property[]
  projects        Project[]
  settings        TenantSettings?
  auditLogs       AuditLog[]
  notifications   Notification[]
}

model User {
  user_id         String   @id @default(uuid())
  tenant_id       String
  name            String
  email           String   @unique
  auth_id         String
  is_global_admin Boolean  @default(false)
  status          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant               Tenant                @relation("TenantUsers", fields: [tenant_id], references: [tenant_id], onDelete: Restrict)
  roleAssignments      RoleAssignment[]
  leaseAgreements      LeaseAgreement[]      @relation("UserLeaseAgreements")
  societyProfiles      SocietyProfile[]      @relation("UserSocietyProfiles")
  dailyProgressReports DailyProgressReport[] @relation("UserDailyReports")
  auditLogs            AuditLog[]
  notifications        Notification[]
}

// =========================================================================
// 2. ADVANCED SCALABLE RBAC ENGINE
// =========================================================================

model RoleTemplate {
  template_id        String   @id @default(uuid())
  name               String
  description        String?
  is_global_template Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  roles Role[]
}

model Role {
  role_id          String   @id @default(uuid())
  tenant_id        String?
  base_template_id String
  name             String
  description      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant          Tenant?          @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)
  baseTemplate    RoleTemplate     @relation(fields: [base_template_id], references: [template_id], onDelete: Restrict)
  rolePermissions RolePermission[]
  assignments     RoleAssignment[]
}

model Permission {
  permission_id String   @id @default(uuid())
  code          String   @unique
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rolePermissions RolePermission[]
}

model RolePermission {
  role_id       String
  permission_id String

  role       Role       @relation(fields: [role_id], references: [role_id], onDelete: Cascade)
  permission Permission @relation(fields: [permission_id], references: [permission_id], onDelete: Cascade)

  @@id([role_id, permission_id])
}

model RoleAssignment {
  id         String   @id @default(uuid())
  user_id    String
  tenant_id  String
  role_id    String
  scope_type String
  scope_id   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User   @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)
  role   Role   @relation(fields: [role_id], references: [role_id], onDelete: Cascade)
}

// =========================================================================
// 3. PHASE 2 PROPERTY CORE HIERARCHY (VISUAL PROPERTY EXPLORER TREE)
// =========================================================================

model Property {
  id            String         @id @default(uuid())
  tenant_id     String
  name          String
  type          String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant        Tenant         @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)
  buildings     Building[]
  UtilityMeters UtilityMeter[]
}

model Building {
  building_id String   @id @default(uuid())
  property_id String
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property Property @relation(fields: [property_id], references: [id], onDelete: Cascade)
  floors   Floor[]
}

model Floor {
  floor_id     String   @id @default(uuid())
  building_id  String
  floor_number Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  building Building @relation(fields: [building_id], references: [building_id], onDelete: Cascade)
  units    Unit[]
}

model Unit {
  unit_id     String   @id @default(uuid())
  floor_id    String
  unit_number String
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customer_id String?

  floor            Floor            @relation(fields: [floor_id], references: [floor_id], onDelete: Cascade)
  leaseAgreements  LeaseAgreement[]
  societyProfiles  SocietyProfile[]
  owner            Customer?        @relation(fields: [customer_id], references: [id])
  parkingSlot      ParkingSlot?
  maintenanceBills MaintenanceBill[]
  interestedUnits  InterestedUnit[]
  workOrders       WorkOrder[]
}

// =========================================================================
// 4. DOMAIN VERTICAL EXTENSIONS
// =========================================================================

model LeaseAgreement {
  id             String   @id @default(uuid())
  unit_id        String
  tenant_user_id String
  rent_amount    Decimal
  start_date     DateTime
  end_date       DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  unit       Unit @relation(fields: [unit_id], references: [unit_id], onDelete: Cascade)
  tenantUser User @relation("UserLeaseAgreements", fields: [tenant_user_id], references: [user_id], onDelete: Restrict)
}

model SocietyProfile {
  id               String   @id @default(uuid())
  unit_id          String
  resident_user_id String
  user_type        String
  gate_pass_code   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  unit         Unit @relation(fields: [unit_id], references: [unit_id], onDelete: Cascade)
  residentUser User @relation("UserSocietyProfiles", fields: [resident_user_id], references: [user_id], onDelete: Restrict)
}

model Project {
  project_id String      @id @default(uuid())
  tenant_id  String
  name       String
  budget     Decimal
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  workOrders WorkOrder[]

  tenant               Tenant                @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)
  dailyProgressReports DailyProgressReport[]
}

model DailyProgressReport {
  report_id                 String   @id @default(uuid())
  project_id                String
  recorded_by_id            String
  work_completed_percentage Decimal
  blockers_or_delays        String?
  log_date                  DateTime
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  project    Project @relation(fields: [project_id], references: [project_id], onDelete: Cascade)
  recordedBy User    @relation("UserDailyReports", fields: [recorded_by_id], references: [user_id], onDelete: Restrict)
}

// =========================================================================
// 5. SYSTEM OPERATIONS
// =========================================================================

model TenantSettings {
  settings_id   String   @id @default(uuid())
  tenant_id     String   @unique
  settings_blob String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)
}

model AuditLog {
  log_id        String   @id @default(uuid())
  tenant_id     String
  user_id       String
  action        String
  resource_type String
  resource_id   String?
  result        String
  timestamp     DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Restrict)
  user   User   @relation(fields: [user_id], references: [user_id], onDelete: Restrict)
}

// =========================================================================
// 6. NOTIFICATIONS
// =========================================================================

model Notification {
  id        String   @id @default(uuid())
  tenant_id String
  user_id   String
  title     String
  message   String
  is_read   Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)
  user   User   @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

// =========================================================================
// 7. NEW CRM & LEAD MANAGEMENT
// =========================================================================

model Lead {
  id              String           @id @default(uuid())
  tenant_id       String
  name            String
  phone           String?
  email           String?
  source          String           @default("ORGANIC")
  status          String           @default("NEW")
  score           Int              @default(0)
  budgetMin       Decimal?
  budgetMax       Decimal?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  activities      LeadActivity[]
  siteVisits      LeadSiteVisit[]
  notes           LeadNote[]
  interestedUnits InterestedUnit[]
}

model LeadActivity {
  id        String   @id @default(uuid())
  tenant_id String
  lead_id   String
  type      String
  title     String
  details   String?
  createdAt DateTime @default(now())

  lead      Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)
}

model LeadSiteVisit {
  id          String   @id @default(uuid())
  tenant_id   String
  lead_id     String
  status      String
  scheduledAt DateTime @default(now())
  createdAt   DateTime @default(now())

  lead        Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)
}

model LeadNote {
  id        String   @id @default(uuid())
  tenant_id String
  lead_id   String
  content   String
  createdAt DateTime @default(now())

  lead      Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)
}

model InterestedUnit {
  id         String   @id @default(uuid())
  tenant_id  String
  lead_id    String
  unit_id    String
  status     String
  reservedAt DateTime @default(now())

  lead       Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  unit       Unit     @relation(fields: [unit_id], references: [unit_id], onDelete: Cascade)
}

// =========================================================================
// 8. DOCUMENT MANAGEMENT
// =========================================================================

model Document {
  id        String   @id @default(uuid())
  tenant_id String
  name      String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =========================================================================
// 9. FACILITY & BOOKING
// =========================================================================

model Facility {
  facility_id String            @id @default(uuid())
  tenant_id   String
  name        String
  description String?
  bookings    FacilityBooking[]
}

model FacilityBooking {
  id           String   @id @default(uuid())
  tenant_id    String
  facility_id  String
  customer_id  String
  status       String
  bookingDate  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  facility     Facility @relation(fields: [facility_id], references: [facility_id], onDelete: Cascade)
  customer     Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
}

// =========================================================================
// 10. MAINTENANCE & BILLING
// =========================================================================

model Invoice {
  invoice_id       String            @id @default(uuid())
  tenant_id        String
  amount           Decimal
  status           String
  createdAt        DateTime          @default(now())
  maintenanceBills MaintenanceBill[]
}

model MaintenanceBill {
  id            String                    @id @default(uuid())
  tenant_id     String
  unit_id       String
  invoice_id    String?
  billingPeriod String
  amount        Decimal
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  unit          Unit                      @relation(fields: [unit_id], references: [unit_id], onDelete: Cascade)
  invoice       Invoice?                  @relation(fields: [invoice_id], references: [invoice_id], onDelete: SetNull)
  lineItems     MaintenanceBillLineItem[]
}

model MaintenanceBillLineItem {
  id          String          @id @default(uuid())
  bill_id     String
  description String
  amount      Decimal

  bill        MaintenanceBill @relation(fields: [bill_id], references: [id], onDelete: Cascade)
}

// =========================================================================
// 11. PREVENTIVE MAINTENANCE
// =========================================================================

model MaintenanceChecklist {
  id        String            @id @default(uuid())
  tenant_id String
  name      String
  createdAt DateTime          @default(now())
  tasks     MaintenanceTask[]
}

model MaintenanceTask {
  id           String               @id @default(uuid())
  checklist_id String
  title        String
  status       String

  checklist    MaintenanceChecklist @relation(fields: [checklist_id], references: [id], onDelete: Cascade)
}

// =========================================================================
// 12. UTILITY METERS
// =========================================================================

model UtilityMeter {
  id           String                   @id @default(uuid())
  tenant_id    String
  property_id  String
  meter_number String
  consumptions UtilityMeterConsumption[]

  property     Property                 @relation(fields: [property_id], references: [id], onDelete: Cascade)
}

model UtilityMeterConsumption {
  id        String   @id @default(uuid())
  meter_id  String
  reading   Decimal
  readAt    DateTime @default(now())

  meter     UtilityMeter @relation(fields: [meter_id], references: [id], onDelete: Cascade)
}

// =========================================================================
// 13. CUSTOMERS / RESIDENTS
// =========================================================================

model Customer {
  id                String                     @id @default(uuid())
  tenant_id         String
  name              String
  email             String?
  phone             String?
  kycStatus         String
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  ownedUnits        Unit[]
  familyMembers     CustomerFamilyMember[]
  pets              CustomerPet[]
  emergencyContacts CustomerEmergencyContact[]
  vehicles          CustomerVehicle[]
  bookings          FacilityBooking[]
}

model CustomerFamilyMember {
  id          String   @id @default(uuid())
  customer_id String
  tenant_id   String
  firstName   String
  lastName    String
  relation    String

  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
}

model CustomerPet {
  id          String   @id @default(uuid())
  customer_id String
  name        String
  type        String

  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
}

model CustomerEmergencyContact {
  id          String   @id @default(uuid())
  customer_id String
  name        String
  phone       String
  relation    String

  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
}

model CustomerVehicle {
  id          String   @id @default(uuid())
  customer_id String
  plateNumber String
  model       String

  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
}

model ParkingSlot {
  id          String @id @default(uuid())
  unit_id     String @unique
  slot_number String

  unit        Unit   @relation(fields: [unit_id], references: [unit_id], onDelete: Cascade)
}

// =========================================================================
// 14. VOTING & POLLS
// =========================================================================

model Poll {
  id        String       @id @default(uuid())
  tenant_id String
  societyId String
  question  String
  createdAt DateTime     @default(now())

  options   PollOption[]
  votes     Vote[]
}

model PollOption {
  id         String   @id @default(uuid())
  pollId     String
  optionText String

  poll       Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes      Vote[]
}

model Vote {
  id          String     @id @default(uuid())
  pollId      String
  optionId    String
  customer_id String

  poll       Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option     PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
}

// =========================================================================
// 15. WORK ORDERS
// =========================================================================

model Vendor {
  vendor_id  String      @id @default(uuid())
  tenant_id  String
  name       String
  email      String?
  phone      String?
  workOrders WorkOrder[]
}

model Complaint {
  id          String      @id @default(uuid())
  tenant_id   String
  title       String
  description String?
  workOrders  WorkOrder[]
}

model WorkOrder {
  id                 String     @id @default(uuid())
  tenant_id          String
  title              String
  description        String?
  status             String     @default("OPEN")
  unit_id            String?
  vendor_id          String?
  complaint_id       String?
  project_id         String?

  unit               Unit?      @relation(fields: [unit_id], references: [unit_id], onDelete: Cascade)
  assignedToVendor   Vendor?    @relation(fields: [vendor_id], references: [vendor_id], onDelete: SetNull)
  complaint          Complaint? @relation(fields: [complaint_id], references: [id], onDelete: SetNull)
  project            Project?   @relation(fields: [project_id], references: [project_id], onDelete: Cascade)
}