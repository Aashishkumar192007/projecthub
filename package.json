{
  "name": "proptrackpro",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.js",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:generate": "npx prisma generate --schema=./prisma/schema.prisma",
    "db:migrate": "dotenv -e .env -- npx prisma migrate dev --schema=./prisma/schema.prisma",
    "dev:api": "npm run --prefix apps/api start:dev",
    "dev:web": "npm run --prefix apps/web dev",
    "dev:legacy-server": "node server/index.js",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev:web\" \"npm run dev:legacy-server\""
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.18.0",
    "bcryptjs": "^3.0.3",
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prisma": "^5.22.0",
    "vite": "^8.0.12",
    "dotenv-cli": "^8.0.0"
  }
}